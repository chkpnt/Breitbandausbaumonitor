        "@rollup/plugin-typescript": "11.1.6",
        "@tsconfig/svelte": "5.0.4",
        "@types/leaflet": "1.9.0",
        "@typescript-eslint/eslint-plugin": "7.4.0",
        "@typescript-eslint/parser": "7.4.0",
        "autoprefixer": "10.4.13",
        "eslint": "8.26.0",
        "eslint-config-prettier": "9.1.0",
        "eslint-plugin-svelte": "2.11.0",
        "postcss": "8.4.18",
